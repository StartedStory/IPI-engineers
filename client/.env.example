# Frontend environment variables (Vite).
# Only variables prefixed with VITE_ are exposed to the browser.

# Leave UNSET for local dev (Vite proxies /api → localhost:4000).
# For production split-hosting, set this to your backend's origin (no trailing /api):
#   VITE_API_URL=https://ipi-api.onrender.com
VITE_API_URL=
