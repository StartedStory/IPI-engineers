PORT=4000
JWT_SECRET=change-me-in-production
CLIENT_ORIGIN=http://localhost:5173

# ─── Supabase ─────────────────────────────────────────────────────────
# From Supabase dashboard → Project Settings → API Keys
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Use the "Secret Key" (formerly called "service_role key"). NEVER ship to the browser.
# Do NOT use the "Publishable Key" — it cannot bypass RLS and the server will not work.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_STORAGE_BUCKET=cvs               # bucket name for developer CV uploads
